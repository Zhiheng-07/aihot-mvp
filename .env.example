# Postgres 数据库（Neon 免费档即可）
# DATABASE_URL 用 pooler 连接串（运行时），DIRECT_DATABASE_URL 用直连串（migrate 用）
DATABASE_URL="postgresql://user:pass@xxx-pooler.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:pass@xxx.neon.tech/neondb?sslmode=require"

# LLM（OpenAI 兼容接口，默认 DeepSeek；智谱/通义等同样适用）
# DeepSeek: https://api.deepseek.com  模型 deepseek-chat
# 智谱:     https://open.bigmodel.cn/api/paas/v4  模型 glm-4-flash / glm-4.5 等
# 通义:     https://dashscope.aliyuncs.com/compatible-mode/v1  模型 qwen-plus 等
LLM_BASE_URL="https://api.deepseek.com"
LLM_API_KEY="sk-..."
LLM_MODEL="deepseek-chat"

# GitHub Releases 抓取（可选，无 token 时限流 60 次/小时，够用）
GITHUB_TOKEN=""

# 站点对外地址（用于 permalink / RSS 输出）
SITE_URL="http://localhost:3000"
